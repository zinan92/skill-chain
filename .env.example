# skill-chain environment configuration
# Copy to .env and customize for your machine

# Root directory of skill-chain (usually where you cloned the repo)
SCO_HOME="${HOME}/skill-chain"

# Target repository for pipeline execution (set per-project)
# TARGET_REPO="${HOME}/my-project"

# Optional: Override Claude model for pipeline steps
# CLAUDE_MODEL="claude-sonnet-4-5"

# Optional: API keys (only needed if not already configured)
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."
